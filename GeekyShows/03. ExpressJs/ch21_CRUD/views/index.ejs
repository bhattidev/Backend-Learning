<%- include( './partial/header.ejs' ) %>

<div class="container">
	<div class="row">
		<div class="col-sm-6 mt-5">
			<h2 class="alert alert-success text-center">Add New Student</h2>
			<form action="post">
				<div class="mb-3">
					<label
						for="name"
						class="form-label"
						>Name</label
					>
					<input
						for="name"
						type="text"
						class="form-control"
						id="name"
						name="name" />
				</div>
				<div class="mb-3">
					<label
						for="age"
						class="form-label"
						>Age</label
					>
					<input
						for="age"
						type="text"
						class="form-control"
						id="age"
						name="age" />
				</div>
				<div class="mb-3">
					<label
						for="fees"
						class="form-label"
						>Fees</label
					>
					<input
						for="fees"
						type="text"
						class="form-control"
						id="fees"
						name="fees" />
				</div>
				<button
					type="submit"
					class="btn btn-primary">
					Submit
				</button>
			</form>
		</div>

		<div class="col-sm-6 mt-5">
			<h2 class="alert alert-danger text-center">List of Student Student</h2>
			<%# Show All Data %>
			<table class="table table-striped table-hover">
				<thead>
					<tr>
						<th scope="col">No</th>
						<th scope="col">Name</th>
						<th scope="col">Age</th>
						<th scope="col">Fees</th>
						<th scope="col">Action</th>
					</tr>
				</thead>
				<tbody>
					<% data.forEach((item, index)=>{ %> 
						<tr>
						<td><%= index+1 %>  </td>
						<td> <%= item.name %>  </td>
						<td><%= item.age %>  </td>
						<td><%= item.fees %>  </td>
						<td>
							<i class="fas fa-pen-square text-info"></i>
							<i class="fas fa-trash text-danger"></i>
						</td>
					</tr>
						<% })  %>
					
				</tbody>
			</table>
		</div>
	</div>
</div>

<%- include( './partial/footer.ejs' ) %>
